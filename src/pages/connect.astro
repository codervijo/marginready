---
import Layout from "../layouts/Layout.astro";
import { ConnectCard } from "../components/ConnectCard";

const site = "https://marginready.com";
const title = "Connect TikTok Shop — MarginReady";
const description =
  "Securely connect your TikTok Shop to MarginReady with read-only access.";
---

<Layout>
  <Fragment slot="head">
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={site + "/connect"} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={site + "/connect"} />
    <meta property="og:site_name" content="MarginReady" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
  </Fragment>

  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-16 sm:py-24">
    <ConnectCard client:load />
  </div>
</Layout>
