---
import Layout from "../layouts/Layout.astro";
import { DashboardView } from "../components/DashboardView";

const site = "https://marginready.com";
const title = "Real profit dashboard — MarginReady";
const description = "Settled TikTok Shop performance after fees and COGS.";
---

<Layout>
  <Fragment slot="head">
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={site + "/dashboard/"} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={site + "/dashboard/"} />
    <meta property="og:site_name" content="MarginReady" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
  </Fragment>

  <DashboardView />
</Layout>
