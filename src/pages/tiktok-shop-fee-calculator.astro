---
import Layout from "../layouts/Layout.astro";
import { TikTokFeeCalculator } from "../components/TikTokFeeCalculator";

const site = "https://marginready.com";
const path = "/tiktok-shop-fee-calculator/";
const url = site + path;
const title =
  "TikTok Shop Fee Calculator — See Your Real Net Profit Per Order";
const description =
  "Free TikTok Shop fee calculator. Enter your price, referral fee, COGS, affiliate commission, fulfillment, and ad spend to see real net profit, net margin, and TikTok's effective take per order.";

// Rates confirmed against TikTok Shop Seller Center. Update this date when re-verified.
const ratesAsOf = "July 2026";

const webApplicationLd = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  name: "TikTok Shop Fee Calculator",
  url,
  description:
    "Calculate the real net profit and net margin per order on TikTok Shop after referral fees, affiliate commissions, fulfillment, returns, and ad spend.",
  applicationCategory: "BusinessApplication",
  operatingSystem: "Web",
  offers: {
    "@type": "Offer",
    price: "0",
    priceCurrency: "USD",
  },
  publisher: { "@id": "https://marginready.com/#organization" },
};

const faqLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "How much does TikTok Shop take?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "In the US, TikTok Shop takes a flat 6% referral fee on most categories (5% on select jewelry), and that fee already includes payment processing. Your effective take climbs to roughly 20–30% of revenue once affiliate commissions, fulfillment, and returns stack on top. Confirm your own category rate in TikTok Seller Center.",
      },
    },
    {
      "@type": "Question",
      name: "What are TikTok Shop seller fees?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "TikTok Shop seller fees are the referral fee (a percentage of order value that includes payment processing), fulfillment costs if you use Fulfilled by TikTok, affiliate/creator commissions you set when working with creators, and the profit lost to returns and refunds.",
      },
    },
    {
      "@type": "Question",
      name: "What is the TikTok Shop commission rate?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "The standard US TikTok Shop commission (referral fee) is a flat 6%, with a 5% exception for select jewelry. Non-US markets differ — the UK moved to 9%. Always confirm your category rate in TikTok Seller Center.",
      },
    },
    {
      "@type": "Question",
      name: "How do I calculate my net profit on TikTok Shop?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Start with revenue (price × units), then subtract the referral fee, any affiliate commission, fulfillment, your product cost (COGS), estimated returns, and ad spend. What remains is your net profit; divide it by revenue for net margin. This calculator does the math live as you type.",
      },
    },
  ],
};
---

<Layout>
  <Fragment slot="head">
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={url} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={url} />
    <meta property="og:site_name" content="MarginReady" />

    <!-- Twitter card -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- JSON-LD structured data -->
    <script type="application/ld+json" is:inline set:html={JSON.stringify(webApplicationLd)} />
    <script type="application/ld+json" is:inline set:html={JSON.stringify(faqLd)} />
  </Fragment>

  <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 py-10 sm:py-14">
    <header class="mb-6">
      <h1 class="text-3xl sm:text-4xl font-semibold tracking-tight">
        TikTok Shop Fee Calculator
      </h1>
      <p class="mt-3 text-muted-foreground max-w-2xl">
        Revenue isn&rsquo;t profit. Enter your numbers below to see your real
        net profit and net margin per order after TikTok&rsquo;s referral fee,
        affiliate commissions, fulfillment, returns, and ad spend — plus how
        much TikTok Shop actually takes.
      </p>
      <p class="mt-3 text-xs text-muted-foreground">
        Rates current as of {ratesAsOf}; confirm your category in TikTok Seller
        Center. This estimator uses your inputs — it does not read your account.
      </p>
    </header>

    <TikTokFeeCalculator client:load />

    <div class="prose-tk mt-14 space-y-12 max-w-3xl">
      <section>
        <h2 class="text-2xl font-semibold tracking-tight">
          How much does TikTok Shop take?
        </h2>
        <p class="mt-3 text-muted-foreground">
          In the US, TikTok Shop takes a <strong class="text-foreground"
            >flat 6% referral fee</strong
          > on most categories (5% on select jewelry). That referral fee already
          includes payment processing, so there is no separate processing charge
          to add on top.
        </p>
        <p class="mt-3 text-muted-foreground">
          But 6% is just the platform&rsquo;s cut. Your
          <strong class="text-foreground">effective take</strong> — everything the
          channel eats before you see profit — typically climbs to
          <strong class="text-foreground">~20–30% of revenue</strong> once affiliate
          commissions, fulfillment, and returns stack on top. The calculator above
          shows this &ldquo;effective take&rdquo; live so you can see it for your
          own numbers. Rates come from the TikTok Shop Seller Center — confirm your
          own category rate there.
        </p>
      </section>

      <section>
        <h2 class="text-2xl font-semibold tracking-tight">
          TikTok Shop seller fees explained
        </h2>
        <ul class="mt-3 space-y-3 text-muted-foreground">
          <li>
            <strong class="text-foreground">Referral fee</strong> — a percentage
            of order value (the standard US rate is 6%). It is charged on the
            selling price before tax and already includes payment processing.
          </li>
          <li>
            <strong class="text-foreground">Fulfillment</strong> — you can ship
            orders yourself or use Fulfilled by TikTok (FBT), which charges a
            per-unit fee (roughly $2.86–$4.28/unit depending on weight and how
            many items ship together; single-item orders start around $3.58).
            TikTok announced a plan to require its own logistics by March 31,
            2026, but reversed it in February 2026 — independent seller shipping
            remains available.
          </li>
          <li>
            <strong class="text-foreground">Affiliate / creator commissions</strong>
            — the rate you set when creators promote your product (commonly
            10–30%). You only pay it on sales creators drive.
          </li>
          <li>
            <strong class="text-foreground">Returns &amp; refunds</strong> — refunded
            orders erase revenue and, in most cases, the product and shipping you
            already spent. A few points of return rate can move your margin
            noticeably.
          </li>
        </ul>
      </section>

      <section>
        <h2 class="text-2xl font-semibold tracking-tight">
          TikTok Shop commission rates
        </h2>
        <p class="mt-3 text-muted-foreground">
          The standard US TikTok Shop commission (referral fee) is a
          <strong class="text-foreground">flat 6%</strong>, with a
          <strong class="text-foreground">5% exception for select jewelry</strong>.
          This replaced the older per-category tables (4–9%) that some outdated
          guides still show — for the US in 2026 it is a single flat rate, not a
          category grid.
        </p>
        <p class="mt-3 text-muted-foreground">
          New US sellers may qualify for a promotional 3% referral rate for their
          first 30 days after an early first sale — a temporary discount, not the
          standing rate. Non-US markets differ: the UK, for example, moved to 9%.
          Whatever market you sell in, confirm the current rate for your exact
          category in TikTok Seller Center before you price.
        </p>
      </section>

      <section>
        <h2 class="text-2xl font-semibold tracking-tight">
          How to use this calculator
        </h2>
        <ol class="mt-3 space-y-2 text-muted-foreground list-decimal pl-5">
          <li>Enter your selling price per unit and how many units sold.</li>
          <li>
            Set the referral fee (6% is the US default), your COGS per unit, and
            any affiliate, fulfillment, return-rate, or ad-spend figures that
            apply.
          </li>
          <li>
            Read the headline <strong class="text-foreground">net profit</strong> and
            <strong class="text-foreground">net margin</strong>, and watch
            TikTok&rsquo;s effective take update as you change any input.
          </li>
        </ol>
        <p class="mt-4 text-sm text-muted-foreground">
          Want profit from your <em>real</em> settled TikTok payouts instead of
          estimates? <a class="underline hover:text-foreground" href="/"
            >MarginReady</a
          > connects to your TikTok Shop account and shows true profit per SKU from
          actual settled fees — no modeling.
        </p>
      </section>
    </div>
  </div>
</Layout>
